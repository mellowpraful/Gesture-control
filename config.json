    "pause": "play_pause",
    "play pause": "play_pause",
    "fullscreen": "fullscreen"
  },
  "gesture_timeout": 2.0,
  "min_detection_confidence": 0.8,
  "min_tracking_confidence": 0.8,
  "max_hands": 2,
