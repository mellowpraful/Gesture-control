{
  "scroll_speed": 200,
  "scroll_cooldown": 0.8,
  "mouse_speed": 1.5,
  "enable_mouse_control": true,
  "enable_volume_control": true,
  "enable_app_shortcuts": true,
  "enable_voice_control": true,
  "voice_cooldown": 0.5,
  "voice_phrase_time_limit": 2,
